# ---------------------------------------------------------------------------
# Knowledge server configuration. Copy to `.env` and edit.
# The calculator server needs no configuration (one optional knob below).
# ---------------------------------------------------------------------------

# Calculator: wall-clock limit (seconds) for compute-heavy tools so a hard
# symbolic integral / dsolve can never hang the session. 0 disables the guard.
CALC_TIMEOUT=12

# Embedding backend: openai | local | hash
#   openai -> needs OPENAI_API_KEY, costs money, best quality
#   local  -> sentence-transformers, runs on your machine, free, good quality
#   hash   -> deterministic offline stub. NO semantic meaning. For tests/CI only.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5      # openai e.g. text-embedding-3-large
OPENAI_API_KEY=

# Vector store: numpy | lancedb | chroma
#   numpy   -> zero extra deps, fine for a personal corpus (a few thousand chunks)
#   lancedb -> scales better, install the `store-lancedb` extra
#   chroma  -> install the `store-chroma` extra
VECTOR_STORE=numpy

# PDF -> Markdown converter: pymupdf4llm | marker
#   pymupdf4llm -> fast, good headings/math (install `pdf-pymupdf`)
#   marker      -> higher quality, much heavier (install `pdf-marker`)
PDF_CONVERTER=pymupdf4llm

# Chunking
CHUNK_TARGET_TOKENS=650      # ~500-800 sweet spot
CHUNK_OVERLAP_RATIO=0.10

# Retrieval
SEARCH_TOP_K=8

# --- Optional full GraphRAG layer (deferred, opt-in) -----------------------
# Leave false unless you frequently ask cross-cutting synthesis questions.
# Enabling it adds per-chunk LLM calls at index time and per-query map-reduce
# token cost, and makes note edits expensive to reindex.
ENABLE_GRAPHRAG=false
LLM_MODEL=                   # only used when ENABLE_GRAPHRAG=true

# Data root (defaults to ./data next to the repo)
# DATA_DIR=
