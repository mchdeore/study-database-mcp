# ---------------------------------------------------------------------------
# Knowledge server configuration. Copy to `.env` and edit.
# The calculator server needs no configuration (one optional knob below).
# ---------------------------------------------------------------------------

# Calculator: wall-clock limit (seconds) for compute-heavy tools so a hard
# symbolic integral / dsolve can never hang the session. 0 disables the guard.
CALC_TIMEOUT=12

# Embedding backend: openai | local | hash
#   openai -> needs OPENAI_API_KEY, costs money, best quality
#   local  -> sentence-transformers, runs on your machine, free, good quality
#   hash   -> deterministic offline stub. NO semantic meaning. For tests/CI only.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5      # openai e.g. text-embedding-3-large
OPENAI_API_KEY=

# Vector store: numpy | lancedb | chroma
#   numpy   -> zero extra deps, fine for a personal corpus (a few thousand chunks)
#   lancedb -> scales better, install the `store-lancedb` extra
#   chroma  -> install the `store-chroma` extra
VECTOR_STORE=numpy

# PDF -> Markdown converter: pymupdf4llm | marker
#   pymupdf4llm -> fast, good headings/math (install `pdf-pymupdf`)
#   marker      -> higher quality, much heavier (install `pdf-marker`)
PDF_CONVERTER=pymupdf4llm

# Chunking
CHUNK_TARGET_TOKENS=650      # ~500-800 sweet spot
CHUNK_OVERLAP_RATIO=0.10

# Retrieval
SEARCH_TOP_K=8

# --- Optional full GraphRAG layer (deferred, opt-in) -----------------------
# Leave false unless you frequently ask cross-cutting synthesis questions.
# Enabling it adds per-chunk LLM calls at index time and per-query map-reduce
# token cost, and makes note edits expensive to reindex.
ENABLE_GRAPHRAG=false

# The "backend librarian" (used only when ENABLE_GRAPHRAG=true). Two roles, so
# you pay a reliability premium only where it counts -- see docs/vision/10-cost.md.
# These are non-secret knobs; the API KEYS live in the encrypted credential store
# (set_credential / scripts/vault_admin.py), referenced by the *_KEY_NAME below.
#
#   AGENTIC   -> drives the MCP tools, dedup/regroup decisions, query-time
#                context-packing. Reliability-first: Kimi K2 (MCP tool-use leader).
#   EXTRACTION-> high-volume, mechanical per-chunk entity/relation extraction
#                (the cost that scales with corpus size). Cost-first: DeepSeek
#                V4 Flash (cheapest capable). Both endpoints are OpenAI-compatible.
LLM_AGENTIC_MODEL=kimi-k2.7-code
LLM_AGENTIC_BASE_URL=https://api.moonshot.ai/v1
LLM_AGENTIC_KEY_NAME=moonshot_api_key
LLM_EXTRACTION_MODEL=deepseek-v4-flash
LLM_EXTRACTION_BASE_URL=https://api.deepseek.com/v1
LLM_EXTRACTION_KEY_NAME=deepseek_api_key

# Data root (defaults to ./data next to the repo)
# DATA_DIR=

# --- Catalog (the SCHOOL document index) -----------------------------------
# Folder of school material to catalog, organized by course code. The catalog
# is a single SQLite file at data/catalog.db (no server/Docker needed).
SCHOOL_DIR=~/Documents/SCHOOL

# Which file types count as "documents" (comma-separated). Everything else --
# code, notebooks, data, virtualenvs -- is skipped.
CATALOG_DOC_EXTS=.pdf,.docx,.pptx,.md,.markdown

# ---------------------------------------------------------------------------
# Life Vault MCP (the "my life" vault server)
# ---------------------------------------------------------------------------
# Where the Markdown vault (source of truth) lives. Defaults to ./vault.
# VAULT_DIR=

# Relational index backend: sqlite (default, zero-ops) | postgres (scale).
VAULT_DB=sqlite
# Required when VAULT_DB=postgres:
POSTGRES_DSN=
# Used by docker-compose.yml to provision Postgres:
POSTGRES_USER=vault
POSTGRES_PASSWORD=
POSTGRES_DB=vault

# HTTP serving (Phase 2). Bind address + port for `server.py --http`.
# Use 0.0.0.0 inside Docker; Tailscale controls who can actually reach it.
VAULT_HOST=127.0.0.1
VAULT_PORT=8765

# Master key that encrypts the secrets file (.vault/secrets.enc) at rest.
# REQUIRED for a real deployment; without it secrets are stored in plaintext.
VAULT_MASTER_KEY=

# --- Google connectors (Phase 4.1: Calendar + Gmail, read-only) ------------
# Install the extra: pip install -e ".[connectors-google]"
# The OAuth client id/secret + refresh token are SECRETS -- do NOT put them here.
# Store them via the set_credential MCP tool or scripts/vault_admin.py:
#   google_oauth_client_id, google_oauth_client_secret  (from Google Cloud Console,
#   OAuth "Desktop app" client), then run the setup_google tool to grant consent.
# Only non-secret tuning knobs live here:
# How far back the FIRST calendar sync reaches (future events always included).
GOOGLE_CALENDAR_SYNC_FROM_DAYS=30
# Gmail search query bounding what gets ingested (it's a firehose). Narrow it,
# e.g. "is:important", "is:starred", "newer_than:7d". Default bounds the first pull.
GOOGLE_GMAIL_QUERY=newer_than:30d
