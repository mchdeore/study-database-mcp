# ---------------------------------------------------------------------------
# Life MCP configuration. Copy to `.env` and edit. Everything has a sensible
# default; you mainly touch this to change the embedder or point at your folders.
# ---------------------------------------------------------------------------

# --- The Librarian: embeddings + retrieval ---------------------------------
# Embedding backend: local | openai | hash
#   local  -> sentence-transformers, runs on your machine, free, private. RECOMMENDED.
#             install: pip install -e ".[embeddings-local]"
#   openai -> needs OPENAI_API_KEY; sends text to a cloud API; costs money.
#   hash   -> deterministic offline stub. NO semantic meaning. Tests/CI only.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5      # openai e.g. text-embedding-3-large
OPENAI_API_KEY=

# Vector store: numpy | lancedb | chroma
#   numpy -> zero extra deps, fine for a personal vault (tens of thousands of chunks)
VECTOR_STORE=numpy

# PDF -> Markdown converter (for school docs): pymupdf4llm | marker
PDF_CONVERTER=pymupdf4llm

# Chunking + retrieval
CHUNK_TARGET_TOKENS=650      # ~500-800 sweet spot
CHUNK_OVERLAP_RATIO=0.10
SEARCH_TOP_K=8

# --- Optional full GraphRAG layer (deferred, opt-in) -----------------------
# Leave false unless you frequently ask cross-cutting synthesis questions.
ENABLE_GRAPHRAG=false
LLM_MODEL=                   # only used when ENABLE_GRAPHRAG=true

# Data root (defaults to ./data next to the repo)
# DATA_DIR=

# --- The SCHOOL document catalog (part of the Librarian) -------------------
# Folder of school material, organized by course code. Stored as a single
# SQLite file at data/catalog.db (no server needed).
SCHOOL_DIR=~/Documents/SCHOOL
CATALOG_DOC_EXTS=.pdf,.docx,.pptx,.md,.markdown

# ---------------------------------------------------------------------------
# The Markdown vault (source of truth) + its derived SQLite index
# ---------------------------------------------------------------------------
# Where the Markdown vault lives. Defaults to ./vault.
# VAULT_DIR=

# Optional: master key that encrypts the credential store (.vault/secrets.enc)
# at rest. Without it, credentials live in plaintext in the gitignored .vault/
# (fine for a local single-user machine). Needs the `crypto` extra.
VAULT_MASTER_KEY=

# --- Google connectors (Calendar + Gmail, read-only) -----------------------
# Install: pip install -e ".[connectors-google]"
# The OAuth client id/secret + refresh token are SECRETS -- do NOT put them here.
# Store them via the set_credential MCP tool, then run setup_google to grant
# consent. Only non-secret tuning knobs live here:
# Calendar sync window (bounds open-ended recurring events so they don't flood
# the vault): how far back the first sync reaches, and how far ahead it caps.
GOOGLE_CALENDAR_SYNC_FROM_DAYS=30
GOOGLE_CALENDAR_SYNC_TO_DAYS=365
# Gmail search query bounding what gets ingested (it's a firehose). Narrow it,
# e.g. "is:important", "is:starred", "newer_than:7d".
GOOGLE_GMAIL_QUERY=newer_than:30d
